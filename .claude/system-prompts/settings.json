{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
      "allow": [
        "Bash(npm run lint)",
        "Bash(npm run test *)",
        "Read(~/.zshrc)"
      ],
      "deny": [
        "Bash(curl *)",
        "Read(./.env)",
        "Read(./.env.*)",
        "Read(./secrets/**)"
      ]
    },
    "env": {
        "CONTEXT7_API_KEY": "${CONTEXT7_API_KEY}",
        "FIRECRAWL_LOCAL_API_URL": "${FIRECRAWL_LOCAL_API_URL}"
    },
    "disabledMcpServers": [
        "claude.ai Atlassian",
        "claude.ai context7",
        "claude.ai Kiwi.com",
        "claude.ai Notion",
        "claude.ai Trivago",
        "claude.ai Vercel"
    ]
  }